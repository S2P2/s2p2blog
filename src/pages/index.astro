---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const sections = [
	{
		href: '/blog/',
		label: 'Blog',
		description: 'Long-form posts about building, learning, and technical decisions.',
	},
	{
		href: '/notes/',
		label: 'Notes',
		description: 'Shorter working notes, references, and fragments worth keeping.',
	},
	{
		href: '/lab/',
		label: 'Lab',
		description: 'Small experiments, demos, visualizations, and custom pages.',
	},
	{
		href: '/projects/',
		label: 'Projects',
		description: 'Selected projects and technical artifacts.',
	},
	{
		href: '/notebooks/',
		label: 'Notebooks',
		description: 'Python and Marimo notebook exports when the site is ready for them.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Personal technical blog</p>
				<h1>{SITE_TITLE}</h1>
				<p class="tagline">Structures • Semantics • Systems • Stuff</p>
				<p class="description">{SITE_DESCRIPTION}</p>
				<div class="actions" aria-label="Primary links">
					<a class="primary" href="/blog/">Read the blog</a>
					<a href="/about/">About</a>
				</div>
			</section>

			<section class="sections" aria-label="Site sections">
				{sections.map((section) => (
					<a class="section-card" href={section.href}>
						<span>{section.label}</span>
						<p>{section.description}</p>
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(100%, 960px);
		margin: 0 auto;
		padding: 4rem 1rem 6rem;
	}

	.hero {
		padding: 5rem 0 4rem;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	h1 {
		margin: 0;
		font-size: clamp(3.5rem, 13vw, 8rem);
		line-height: 0.9;
		letter-spacing: -0.08em;
	}

	.tagline {
		max-width: 780px;
		margin: 1rem 0 0;
		font-size: clamp(1.5rem, 4vw, 2.75rem);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.04em;
		color: rgb(var(--black));
	}

	.description {
		max-width: 640px;
		margin: 1.5rem 0 0;
		font-size: clamp(1.1rem, 2vw, 1.35rem);
		line-height: 1.6;
		color: rgb(var(--gray));
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.actions a,
	.section-card {
		text-decoration: none;
	}

	.actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		padding: 0.75rem 1rem;
		color: rgb(var(--black));
		font-weight: 700;
	}

	.actions a:hover,
	.actions a:focus-visible,
	.section-card:hover,
	.section-card:focus-visible {
		border-color: rgb(var(--accent));
		box-shadow: var(--box-shadow);
	}

	.actions .primary {
		background: rgb(var(--black));
		border-color: rgb(var(--black));
		color: white;
	}

	.sections {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.section-card {
		display: block;
		min-height: 150px;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 1.25rem;
		padding: 1.25rem;
		color: rgb(var(--black));
		background: white;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.section-card:hover,
	.section-card:focus-visible {
		transform: translateY(-2px);
	}

	.section-card span {
		display: block;
		font-size: 1.15rem;
		font-weight: 800;
	}

	.section-card p {
		margin: 0.75rem 0 0;
		line-height: 1.5;
		color: rgb(var(--gray));
	}

	@media (max-width: 720px) {
		main {
			padding-top: 2rem;
		}

		.hero {
			padding-top: 3rem;
		}
	}
</style>
